# Neon: Project → Connect → copy connection string
DATABASE_URL="postgresql://user:password@endpoint.neon.tech/neondb?sslmode=require"

# API gateway — realtime-gateway base URL (interviews list, status, …). Override locally if needed.
# На Vercel / NODE_ENV=production обязателен (иначе join-resolver, /api/gateway и /api/stream/token вернут 503).
BACKEND_GATEWAY_URL="http://137.184.25.239:8080"

# Если 1 — выдача Stream token для role=spectator только при joinToken (подписанная ссылка) или сессии HR (prototype / Better Auth).
# STREAM_SPECTATOR_REQUIRE_JOIN_TOKEN="1"

# Защита POST /api/jobai/ingest: при задании требуется заголовок x-jobai-ingest-inbound-secret ИЛИ залогиненный пользователь (cookies).
# JOBAI_INGEST_INBOUND_SECRET=""

# Диагностика контекста интервью (консоль: gateway ↔ merge ↔ session.update). 1 = включить.
# NEXT_PUBLIC_DEBUG_INTERVIEW_CONTEXT="1"
# Внутренняя панель отладки в shell (в т.ч. JSON «последний контекст агента»).
# NEXT_PUBLIC_INTERNAL_DEBUG_UI="1"

# After each successful JobAI status update, the app POSTs { id, status } here (secret stays server-side only).
JOBAI_INGEST_WEBHOOK_URL="http://137.184.25.239:8080/webhooks/jobai/interviews"
JOBAI_INGEST_SECRET="replace-with-gateway-JOBAI_INGEST_SECRET"

# Better Auth — openssl rand -base64 32 (or: npx auth secret)
BETTER_AUTH_SECRET=""
# Optional: signed demo cookie (defaults to BETTER_AUTH_SECRET if unset)
# DEMO_SESSION_SECRET=""
# App origin (server); must match how the browser reaches the app
BETTER_AUTH_URL="http://localhost:3000"
# Optional: same URL for the client bundle (e.g. production https://your-domain.com)
# NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# Optional OAuth (enable GitHub and/or Google in lib/auth.ts when both id+secret are set)
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# HR avatar fallback (temporary external visual provider).
HR_AVATAR_FALLBACK_ENABLED="0"
HR_AVATAR_FALLBACK_API_BASE_URL="https://lab.anam.ai"
HR_AVATAR_FALLBACK_API_KEY=""
HR_AVATAR_FALLBACK_PERSONA_SHARE_URL=""
# Visual-only mode (your OpenAI realtime audio -> avatar lip-sync):
HR_AVATAR_FALLBACK_AUDIO_PASSTHROUGH_ENABLED="0"
# Set one of IDs below for session token minting:
HR_AVATAR_FALLBACK_PERSONA_ID=""
HR_AVATAR_FALLBACK_AVATAR_ID=""
